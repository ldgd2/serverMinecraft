# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── PyInstaller build artifacts ──────────────────────────────────────────────
# Exclude the compiled dist/ folder (exe is copied to server/static/versions/)
minecraftLauncher/dist/
minecraftLauncher/build/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Secrets ──────────────────────────────────────────────────────────────────
*.env
!.env.example

# ── Server static: ALLOW versioned executables in git ────────────────────────
# Los ejecutables del launcher viven aquí y se suben al repo
# para que el VPS solo haga git pull
!server/static/versions/
!server/static/versions/**
!server/static/versions.json

# ── Flutter ──────────────────────────────────────────────────────────────────
appserve/.dart_tool/
appserve/build/

# ── Minecraft mod ────────────────────────────────────────────────────────────
mod/build/
mod/.gradle/
